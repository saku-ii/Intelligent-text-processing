#include <stdio.h>
#include <string.h>

#define MAX_LINE 100
#define MAX_LEN  256
typedef struct {
    char data[MAX_LINE][MAX_LEN];
    int length;
} SeqList;

SeqList textList;
char currentFile[100] = "";
int isSaved = 1;

void showMenu() {
    printf("\n===== 文本编辑器 =====\n");
    printf("1. 新建文件\n");
    printf("2. 打开文件\n");
    printf("3. 编辑内容\n");
    printf("4. 保存文件\n");
    printf("5. 退出\n");
    printf("请选择操作: ");
}
void readFile() {
    char filename[100];
    printf("请输入你要打开的文件名：");
    scanf("%s",filename);
    getchar();

    FILE* fp = fopen(filename, "r");
    if (fp == NULL) {
        printf("打开失败，文件不存在\n");
        return;
    }

    textList.length = 0;
    while (fgets(textList.data[textList.length], MAX_LEN, fp)) {
        textList.data[textList.length][strcspn(textList.data[textList.length], "\n")] = 0;
        textList.length++;
    }
    fclose(fp);
    printf("\n读取成功，内容如下：\n");
    printf("---------------------------------------\n");
    for (int i = 0; i < textList.length; i++) {
        printf("%s\n",textList.data[i]);
    }
    printf("---------------------------------------\n");

    strcpy(currentFile, filename);
    isSaved = 1;
}
void saveFile() {
    char filename[100];
    if (strlen(currentFile) > 0) {
        strcpy(filename, currentFile);
    } else {
        printf("请输入保存的文件名：");
        scanf("%s",filename);
        getchar();
        strcpy(currentFile, filename);
    }

    FILE* fp = fopen(filename, "w");
    if (fp == NULL) {
        printf("保存失败\n");
        return;
    }
    for (int i = 0; i < textList.length; i++) {
        fprintf(fp, "%s\n", textList.data[i]);
    }
    fclose(fp);
    printf("保存成功！\n");
    isSaved = 1;
}
void editText() {
    printf("\n当前内容：\n");
    printf("---------------------------------------\n");
    for (int i = 0; i < textList.length; i++) {
        printf("%s\n",textList.data[i]);
    }
    printf("---------------------------------------\n");

    printf("请输入新的内容（空行结束）：\n");
    textList.length = 0;
    char line[MAX_LEN];

    while (1) {
        fgets(line, MAX_LEN,stdin);
        line[strcspn(line,"\n")]=0;
        if (strlen(line) == 0) break;
        strcpy(textList.data[textList.length], line);
        textList.length++;
    }
    printf("修改完成，请保存\n");
    isSaved = 0;
}
int main() {
    textList.length = 0;

    while (1) {
        showMenu();
        int choice;
        scanf("%d",&choice);
        getchar();

        switch (choice) {
            case 1:
                textList.length = 0;
                currentFile[0] = '\0';
                isSaved = 0;
                printf("已新建空白文件。\n");
                break;

            case 2:
                readFile();
                break;

            case 3:
                editText();
                break;

            case 4:
                saveFile();
                break;

            case 5:
                if (!isSaved) {
                    printf("文件未保存，是否退出？(y/n)：");
                    char c;
                    scanf("%c",&c);
                    if (c != 'y' && c != 'Y') break;
                }
                printf("退出程序。\n");
                return 0;

            default:
                printf("无效选项，请重新选择。\n");
        }
    }
}
